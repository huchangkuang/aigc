{
  "name": "aigc",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @aigc/web dev",
    "dev:api": "pnpm --filter @aigc/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @aigc/web build",
    "build:api": "pnpm --filter @aigc/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}

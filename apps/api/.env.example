# 生产 pm2 用 3011（与同机其他项目 3001 错开）；本地 pnpm dev 可改为 3001
PORT=3011
DATABASE_URL=mysql://root:你的root密码@localhost:3306/aigc

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PRESET_USERS=admin@example.com:changeme

# Volcengine Jimeng
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=

# Alibaba OSS
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# Set to true to skip real OSS uploads in local dev
STORAGE_MOCK=true

# Poll interval for Jimeng tasks (ms)
GENERATION_POLL_INTERVAL_MS=5000

PORT=3001
DATABASE_URL=mysql://aigc:aigc_password@localhost:3307/aigc

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PRESET_USERS=admin@example.com:changeme

# Volcengine Jimeng
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=

# Alibaba OSS
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# Set to true to skip real OSS uploads in local dev
STORAGE_MOCK=true

# Poll interval for Jimeng tasks (ms)
GENERATION_POLL_INTERVAL_MS=5000
